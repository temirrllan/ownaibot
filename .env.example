# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# Файл .env НЕ должен попадать в git (см. .gitignore).

# --- Telegram (с https://my.telegram.org -> API development tools) ---
API_ID=123456
API_HASH=your_api_hash_here

# --- OpenAI ---
OPENAI_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Управляющий бот (токен от @BotFather). ---
# Если оставить пустым — мониторинг включается сразу при старте (без /start /stop).
# Если задать — управление через бота: /start /stop /status.
BOT_TOKEN=

# --- Необязательные параметры (можно не задавать, есть значения по умолчанию) ---
SESSION_NAME=userbot
BACKFILL_HOURS=24
BACKFILL_LIMIT_PER_CHANNEL=50
MIN_LEN=60
DEDUP_MAX=5000
BACKFILL_DELAY_SEC=0.7

# Описание интересов можно переопределить здесь (многострочно не очень удобно
# в .env, поэтому проще править прямо в userbot.py -> MY_INTERESTS).
# MY_INTERESTS=...
